{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZenLink",
  "version": "0.1.0",
  "identifier": "com.zenlink.app",
  "build": {
    "devtools": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZenLink",
        "width": 420,
        "height": 480,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "clipboard-manager": {},
    "global-shortcut": {}
  }
}